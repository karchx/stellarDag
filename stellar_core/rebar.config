{erl_opts, [debug_info]}.
{deps, [
    {epgsql, "4.8.0"},
    {poolboy, "1.5.2"}
]}.

{shell, [
    %% {config, "config/sys.config"},
    {apps, [stellar_core]}
]}.

{relx, [
    {release, {stellar_core, "0.1.0"}, [
        stellar_core,
        sasl
    ]},

    {dev_mode, false},
    {include_erts, true},

    {extended_start_script, true},
    {vm_args_src, "config/vm.args.src"}
]}.
